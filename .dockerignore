.dockerignore
# =============================================================================
# AllanVarianceStudio — .dockerignore
# =============================================================================
# Prevents unnecessary files from being copied into the Docker build context,
# reducing image size and improving build performance.
# =============================================================================

# ---------------------------------------------------------------------------
# Git
# ---------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
.github

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# IDEs and Editors
# ---------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
.pytest_cache
.coverage
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------------------
docs/_build/
site/

# ---------------------------------------------------------------------------
# Data and Outputs (large files)
# ---------------------------------------------------------------------------
*.bag
*.csv
*.mat
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
outputs/
plots/
results/
data/

# ---------------------------------------------------------------------------
# Android (if not needed in container)
# ---------------------------------------------------------------------------
android/
*.apk
*.aab
.gradle/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
Dockerfile*
docker-compose*
.dockerignore

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
README.md
LICENSE
CHANGELOG.md
SECURITY.md
PULL_REQUEST_TEMPLATE.md
